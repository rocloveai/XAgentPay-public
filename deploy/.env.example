# ═══════════════════════════════════════
# XAgentPay Production Environment
# Copy this file to .env and fill values
# ═══════════════════════════════════════

# Database
DB_PASSWORD=your_db_password_here

# XAgent Core - Relayer (Ethereum private key with 0x prefix)
RELAYER_PRIVATE_KEY=0x_your_relayer_private_key_here

# Flight Agent
DUFFEL_API_TOKEN=
MERCHANT_SIGNER_PRIVATE_KEY_FLIGHT=0x_your_flight_signer_key_here

# Hotel Agent
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
MERCHANT_SIGNER_PRIVATE_KEY_HOTEL=0x_your_hotel_signer_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Order Panel
TG_ORDER_BOT_TOKEN=your_telegram_order_bot_token_here
