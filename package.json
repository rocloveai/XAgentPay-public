{
    "name": "nexuspay-monorepo",
    "private": true,
    "description": "NexusPay Web3 Payment Orchestration Monorepo",
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "build": "npm run build -w @nexuspay/core && npm run build --workspaces --if-present",
        "test": "npm test --workspaces --if-present"
    },
    "devDependencies": {
        "typescript": "^5.0.0",
        "@types/node": "^20.0.0"
    }
}